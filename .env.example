# Postgres connection.
# Local (docker compose up): the line below matches docker-compose.yml.
# Production: replace with your Neon connection string.
DATABASE_URL=postgres://trellis:trellis@localhost:5440/trellis
PORT=8787

# Chat intake (optional). The chat bot is built only when an adapter's
# credentials are present; absent these, /integrations/chat/:provider returns
# 503 and nothing else is affected.
#   Slack — from your Slack app (both required to enable Slack):
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_SIGNING_SECRET=...
#   Google Chat — set one of these to enable (fail-closed verification):
# GOOGLE_CHAT_PROJECT_NUMBER=...
# GOOGLE_CHAT_PUBSUB_AUDIENCE=...
#   Optional tuning:
# CHAT_BOT_USERNAME=trellis        # bot display name (default: trellis)
# CHAT_CAPTURE_EMOJI=inbox_tray    # reaction that captures a message (default: inbox_tray / 📥)
